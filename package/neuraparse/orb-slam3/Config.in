config BR2_PACKAGE_ORB_SLAM3
	bool "orb-slam3"
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on !BR2_STATIC_LIBS
	select BR2_PACKAGE_OPENCV_MINIMAL
	select BR2_PACKAGE_EIGEN
	help
	  ORB-SLAM3 is a real-time SLAM library for Monocular, Stereo
	  and RGB-D cameras that computes the camera trajectory and a
	  sparse 3D reconstruction.
	  
	  Features:
	  - Visual, Visual-Inertial and Multi-Map SLAM
	  - Monocular, Stereo, RGB-D and Fisheye cameras
	  - Real-time performance
	  - Loop closing and relocalization
	  - Map reuse and merging
	  
	  https://github.com/UZ-SLAMLab/ORB_SLAM3

if BR2_PACKAGE_ORB_SLAM3

config BR2_PACKAGE_ORB_SLAM3_VIEWER
	bool "Enable Pangolin viewer"
	help
	  Enable Pangolin-based 3D visualization viewer.

endif

comment "orb-slam3 needs a toolchain w/ C++, threads, dynamic library"
	depends on !BR2_INSTALL_LIBSTDCPP || !BR2_TOOLCHAIN_HAS_THREADS || BR2_STATIC_LIBS

