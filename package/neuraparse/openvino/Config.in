config BR2_PACKAGE_OPENVINO
	bool "openvino"
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_TOOLCHAIN_GCC_AT_LEAST_11
	help
	  Intel OpenVINO toolkit for optimizing and deploying
	  AI inference on Intel hardware and ARM.

	  Features:
	  - Model optimization and quantization
	  - Support for ONNX, TensorFlow, PyTorch models
	  - Intel CPU/GPU/NPU acceleration
	  - ARM CPU support via ARM Compute Library
	  - Low-latency inference

	  https://docs.openvino.ai/

if BR2_PACKAGE_OPENVINO

config BR2_PACKAGE_OPENVINO_NPU
	bool "Enable NPU support"
	help
	  Enable Intel Neural Processing Unit support for
	  dedicated AI acceleration.

config BR2_PACKAGE_OPENVINO_PYTHON
	bool "Enable Python bindings"
	depends on BR2_PACKAGE_PYTHON3
	select BR2_PACKAGE_PYTHON_NUMPY
	help
	  Enable Python bindings for OpenVINO inference API.

endif
