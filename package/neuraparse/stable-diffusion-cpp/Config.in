config BR2_PACKAGE_STABLE_DIFFUSION_CPP
	bool "stable-diffusion-cpp"
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS
	help
	  stable-diffusion.cpp - Stable Diffusion inference in C/C++

	  Inference of Stable Diffusion image generation models in
	  pure C/C++ using ggml tensor library (same as llama.cpp).

	  Key Features:
	  - No dependencies, pure C/C++ implementation
	  - Support for SD 1.x, 2.x, SDXL, SD 3.5
	  - GGUF model format for efficient loading
	  - Text-to-image generation
	  - Image-to-image transformation
	  - Inpainting and outpainting
	  - ControlNet support
	  - LoRA adapter support
	  - VAE tiling for high-resolution

	  GPU Acceleration:
	  - CUDA (NVIDIA)
	  - Metal (Apple)
	  - Vulkan (cross-platform)
	  - SYCL (Intel)

	  Memory Requirements:
	  - SD 1.5: ~2GB RAM (quantized)
	  - SDXL: ~4GB RAM (quantized)

	  https://github.com/leejet/stable-diffusion.cpp

if BR2_PACKAGE_STABLE_DIFFUSION_CPP

config BR2_PACKAGE_STABLE_DIFFUSION_CPP_CUDA
	bool "CUDA acceleration"
	help
	  Enable NVIDIA CUDA GPU acceleration.

config BR2_PACKAGE_STABLE_DIFFUSION_CPP_VULKAN
	bool "Vulkan acceleration"
	help
	  Enable Vulkan GPU acceleration.

config BR2_PACKAGE_STABLE_DIFFUSION_CPP_FLASH_ATTN
	bool "Flash Attention"
	help
	  Enable Flash Attention for faster generation.

endif
