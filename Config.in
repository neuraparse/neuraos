# Advanced AI Frameworks
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/apache-tvm/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/mediapipe/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/pytorch-executorch/Config.in"

# LLM Inference
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/llama-cpp/Config.in"

# Computer Vision
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/opencv-minimal/Config.in"
