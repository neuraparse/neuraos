menu "NeuralOS (NeuraParse) external packages"

# AI/ML Frameworks
menu "AI/ML Frameworks"
# Core Inference Engines
# NOTE: Using Buildroot's built-in packages where available
# Custom packages only for those not in Buildroot

# Lightweight ML
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/emlearn/Config.in"

# Advanced AI Frameworks (not in Buildroot 2024.02)
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/apache-tvm/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/mediapipe/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/pytorch-executorch/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/ncnn/Config.in"

# AI Runtimes
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/litert/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/onnxruntime/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/wasmedge/Config.in"

# LLM Inference
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/llama-cpp/Config.in"

# Speech & Audio AI
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/whisper-cpp/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/piper-tts/Config.in"

# Image Generation
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/stable-diffusion-cpp/Config.in"

# Computer Vision
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/opencv5/Config.in"

# Intel AI Toolkit
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/openvino/Config.in"
endmenu

# Quantum Computing
menu "Quantum Computing"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/qiskit-aer/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/pennylane/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/xacc/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/quest/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/qulacs/Config.in"
endmenu

# Robotics & Drone Systems
menu "Robotics & Drone Systems"
# Real-time Communication
# NOTE: Using Buildroot's built-in zeromq and grpc packages
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/fastcdr/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/asio/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/foonathan-memory/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/fast-dds/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/zenoh/Config.in"
# zeromq - use Buildroot's BR2_PACKAGE_ZEROMQ
# grpc - use Buildroot's BR2_PACKAGE_GRPC

# Drone Autopilot
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/mavlink/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/px4-autopilot/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/mavsdk/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/ardupilot/Config.in"

# ROS 2 Support
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/ros2-micro/Config.in"

# SLAM & Perception
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/orb-slam3/Config.in"
endmenu

# AI Model Deployment Tools
menu "AI Model Deployment Tools"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/onnx-tools/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/model-optimizer/Config.in"
endmenu

# Defense & Security
menu "Defense & Security"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/defense-tools/Config.in"
endmenu

# NeuralOS Core Components
menu "NeuralOS Core Components"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/npie/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/npi-init/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/neuraos-dashboard/Config.in"
source "$BR2_EXTERNAL_NEURAOS_PATH/package/neuraparse/neuraos-tests/Config.in"
endmenu

endmenu
