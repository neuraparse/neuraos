# NeuralOS .gitignore

# ===================
# Build Output
# ===================
buildroot-*/
neuraos-images/
neuraos-images-*/
build-output/
output/

# ===================
# Sensitive Files
# ===================
.env
.env.*
*.env
*.key
*.pem
*.crt
*.p12
*.pfx
*credentials*
*secret*
*.keystore
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
known_hosts

# Database files
*.db
*.sqlite
*.sqlite3
users.db

# ===================
# Web Panel (Dev)
# ===================
web/
neuraos-web/

# ===================
# OS/Editor
# ===================
.DS_Store
.AppleDouble
Thumbs.db
*.swp
*.swo
*.tmp
*.bak
*.orig
*~

# ===================
# IDE
# ===================
.idea/
.vscode/
*.code-workspace
.project
.settings/
*.sublime-*

# ===================
# Build Artifacts
# ===================
/build/
/build-*/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
compile_commands.json

# Object files
*.o
*.obj
*.lo
*.la
*.a
*.so
*.dylib
*.dll
*.exe
*.out
*.elf

# ===================
# Archives/Images
# ===================
*.img
*.iso
*.tar
*.tar.*
*.tgz
*.zip
*.7z
*.xz
*.bz2
*.gz
!*.mk

# ===================
# Logs
# ===================
*.log
logs/
/tmp/

# ===================
# Python
# ===================
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/
*.egg-info/

# ===================
# Node.js
# ===================
node_modules/
package-lock.json
pnpm-lock.yaml
yarn.lock

# ===================
# AI Models (large)
# ===================
models/**/*.tflite
models/**/*.onnx
models/**/*.pb
models/**/*.pt
models/**/*.pth
models/**/*.bin
models/**/*.gguf
models/**/*.safetensors

# ===================
# Local Dev Files
# ===================
BUILD_SUCCESS.md
DEVELOPMENT.md
STATUS.txt
TEST_RESULTS.md
*.disabled
*.disabled/
.claude/

# ===================
# Coverage/Test
# ===================
coverage/
*.gcno
*.gcda
*.gcov
htmlcov/
.coverage
