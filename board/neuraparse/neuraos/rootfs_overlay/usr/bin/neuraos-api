#!/usr/bin/env python3
"""
NeuraOS Web API Server
Provides system metrics and command execution for the web control panel
"""

import http.server
import json
import os
import subprocess
import re
from urllib.parse import urlparse, parse_qs

PORT = 8080

class NeuraOSHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        # Suppress default logging
        pass

    def send_json(self, data, status=200):
        self.send_response(status)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type')
        self.end_headers()
        self.wfile.write(json.dumps(data).encode())

    def do_OPTIONS(self):
        self.send_response(200)
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type')
        self.end_headers()

    def get_system_info(self):
        hostname = subprocess.getoutput('hostname').strip()
        kernel = subprocess.getoutput('uname -r').strip()
        arch = subprocess.getoutput('uname -m').strip()
        uptime = subprocess.getoutput("cat /proc/uptime | awk '{print int($1/3600)\":\"int(($1%3600)/60)}'").strip()
        load = subprocess.getoutput("cat /proc/loadavg | awk '{print $1, $2, $3}'").split()

        python_ver = subprocess.getoutput('python3 --version 2>/dev/null').replace('Python ', '').strip()
        numpy_ver = subprocess.getoutput("python3 -c 'import numpy; print(numpy.__version__)' 2>/dev/null").strip()

        return {
            'hostname': hostname,
            'kernel': kernel,
            'arch': arch,
            'os': 'NeuralOS',
            'uptime': uptime,
            'load': load if len(load) >= 3 else ['0', '0', '0'],
            'python': python_ver if python_ver else None,
            'numpy': numpy_ver if numpy_ver and 'Error' not in numpy_ver else None
        }

    def get_cpu_info(self):
        model = subprocess.getoutput("grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2").strip()
        cores = int(subprocess.getoutput("nproc").strip() or '1')

        # Calculate CPU usage
        try:
            stat1 = subprocess.getoutput("head -1 /proc/stat")
            subprocess.run(['sleep', '0.1'], check=True)
            stat2 = subprocess.getoutput("head -1 /proc/stat")

            def parse_stat(s):
                parts = s.split()[1:8]
                return [int(x) for x in parts]

            s1, s2 = parse_stat(stat1), parse_stat(stat2)
            idle_delta = s2[3] - s1[3]
            total_delta = sum(s2) - sum(s1)
            usage = 100 * (1 - idle_delta / total_delta) if total_delta > 0 else 0
        except:
            usage = 0

        return {
            'model': model or 'Unknown CPU',
            'cores': cores,
            'usage': round(usage, 1)
        }

    def get_memory_info(self):
        meminfo = {}
        with open('/proc/meminfo', 'r') as f:
            for line in f:
                parts = line.split(':')
                if len(parts) == 2:
                    key = parts[0].strip()
                    value = int(parts[1].strip().split()[0])
                    meminfo[key] = value

        total = meminfo.get('MemTotal', 0)
        available = meminfo.get('MemAvailable', meminfo.get('MemFree', 0))
        used = total - available
        percent = round(100 * used / total, 1) if total > 0 else 0

        return {
            'MemTotal': total,
            'MemAvailable': available,
            'used': used,
            'percent': percent
        }

    def get_disk_info(self):
        disks = []
        output = subprocess.getoutput("df -h | grep -E '^/dev'")
        for line in output.strip().split('\n'):
            if line:
                parts = line.split()
                if len(parts) >= 6:
                    disks.append({
                        'device': parts[0],
                        'size': parts[1],
                        'used': parts[2],
                        'avail': parts[3],
                        'percent': int(parts[4].replace('%', '')),
                        'mount': parts[5]
                    })
        return disks

    def get_network_info(self):
        interfaces = []
        output = subprocess.getoutput("ip -o link show | grep -v lo")
        for line in output.strip().split('\n'):
            if line:
                match = re.match(r'\d+:\s+(\S+)@?\S*:', line)
                if match:
                    name = match.group(1)
                    state = 'UP' if 'state UP' in line else 'DOWN'

                    # Get MAC
                    mac_match = re.search(r'link/ether\s+([0-9a-f:]+)', line)
                    mac = mac_match.group(1) if mac_match else ''

                    # Get IP
                    ip_output = subprocess.getoutput(f"ip -o -4 addr show {name}")
                    ip_match = re.search(r'inet\s+(\S+)', ip_output)
                    ipv4 = [ip_match.group(1)] if ip_match else []

                    interfaces.append({
                        'name': name,
                        'state': state,
                        'ipv4': ipv4,
                        'mac': mac
                    })
        return interfaces

    def get_processes(self):
        processes = []
        output = subprocess.getoutput("ps aux | tail -n +2 | head -50")
        for line in output.strip().split('\n'):
            if line:
                parts = line.split(None, 10)
                if len(parts) >= 11:
                    processes.append({
                        'user': parts[0],
                        'pid': parts[1],
                        'cpu': parts[2],
                        'mem': parts[3],
                        'cmd': parts[10]
                    })
        return processes

    def get_services(self):
        services = []
        init_scripts = subprocess.getoutput("ls /etc/init.d/S* 2>/dev/null")
        for script in init_scripts.strip().split('\n'):
            if script and script.startswith('/etc/init.d/S'):
                name = os.path.basename(script)
                # Check if running
                service_name = name[3:] if name.startswith('S') else name
                running = subprocess.getoutput(f"{script} status 2>/dev/null").lower()
                is_running = 'running' in running or 'ok' in running.lower()
                services.append({
                    'name': service_name,
                    'script': script,
                    'running': is_running
                })
        return services

    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path

        if path == '/api/all':
            data = {
                'system': self.get_system_info(),
                'cpu': self.get_cpu_info(),
                'memory': self.get_memory_info(),
                'disk': self.get_disk_info(),
                'network': self.get_network_info(),
                'processes': self.get_processes(),
                'services': self.get_services()
            }
            self.send_json(data)
        elif path == '/api/health':
            self.send_json({'status': 'ok'})
        else:
            self.send_json({'error': 'Not found'}, 404)

    def do_POST(self):
        parsed = urlparse(self.path)
        path = parsed.path

        content_length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(content_length).decode() if content_length > 0 else '{}'

        try:
            data = json.loads(body)
        except:
            data = {}

        if path == '/api/exec':
            cmd = data.get('cmd', '')
            if cmd:
                try:
                    result = subprocess.run(
                        cmd, shell=True, capture_output=True, text=True, timeout=30
                    )
                    output = result.stdout or result.stderr
                    self.send_json({'output': output, 'code': result.returncode})
                except subprocess.TimeoutExpired:
                    self.send_json({'error': 'Command timed out'}, 408)
                except Exception as e:
                    self.send_json({'error': str(e)}, 500)
            else:
                self.send_json({'error': 'No command provided'}, 400)

        elif path == '/api/service':
            service = data.get('service', '')
            action = data.get('action', '')

            if service and action in ['start', 'stop', 'restart']:
                script = f"/etc/init.d/S*{service}"
                scripts = subprocess.getoutput(f"ls {script} 2>/dev/null")
                if scripts:
                    result = subprocess.run(
                        f"{scripts.split()[0]} {action}",
                        shell=True, capture_output=True, text=True
                    )
                    self.send_json({'success': result.returncode == 0})
                else:
                    self.send_json({'error': 'Service not found'}, 404)
            else:
                self.send_json({'error': 'Invalid request'}, 400)
        else:
            self.send_json({'error': 'Not found'}, 404)

if __name__ == '__main__':
    print(f"NeuraOS API Server starting on port {PORT}...")
    server = http.server.HTTPServer(('0.0.0.0', PORT), NeuraOSHandler)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down...")
        server.shutdown()
