# NeuralOS Minimal Configuration (No GUI)
# Buildroot 2025.08.1 + Linux 6.12 LTS + PREEMPT_RT

#
# Target Architecture
#
BR2_aarch64=y
BR2_cortex_a53=y

#
# Build Options
#
BR2_OPTIMIZE_2=y
BR2_ENABLE_LTO=y
BR2_TOOLCHAIN_BUILDROOT_WCHAR=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y

#
# System Configuration
#
BR2_TARGET_GENERIC_HOSTNAME="neuraos"
BR2_TARGET_GENERIC_ISSUE="Welcome to NeuralOS - AI-Native Embedded OS"
BR2_ROOTFS_DEVICE_CREATION_DYNAMIC_EUDEV=y
BR2_TARGET_GENERIC_ROOT_PASSWD="neuraos"
BR2_SYSTEM_DHCP="eth0"

#
# Kernel - Linux 6.12 LTS with native PREEMPT_RT
#
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="6.12.57"
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_NEURAOS_PATH)/configs/kernel/neuraos_defconfig"
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y

#
# Filesystem
#
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_EXT2_SIZE="512M"

#
# Bootloader - U-Boot 2025.01
#
BR2_TARGET_UBOOT=y
BR2_TARGET_UBOOT_BUILD_SYSTEM_KCONFIG=y
BR2_TARGET_UBOOT_CUSTOM_VERSION=y
BR2_TARGET_UBOOT_CUSTOM_VERSION_VALUE="2025.01"
BR2_TARGET_UBOOT_BOARD_DEFCONFIG="qemu_arm64"
BR2_TARGET_UBOOT_NEEDS_DTC=y
BR2_TARGET_UBOOT_FORMAT_BIN=y

#
# Essential Packages
#
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_SHOW_OTHERS=y

#
# Networking
#
BR2_PACKAGE_DROPBEAR=y
BR2_PACKAGE_IPTABLES=y
BR2_PACKAGE_IPROUTE2=y

#
# Development Tools
#
BR2_PACKAGE_GDB=y
BR2_PACKAGE_GDB_SERVER=y
BR2_PACKAGE_STRACE=y

#
# System Utilities
#
BR2_PACKAGE_HTOP=y
BR2_PACKAGE_PROCPS_NG=y

#
# Filesystem Tools
#
BR2_PACKAGE_E2FSPROGS=y
BR2_PACKAGE_DOSFSTOOLS=y

#
# Compression Tools
#
BR2_PACKAGE_BZIP2=y
BR2_PACKAGE_GZIP=y
BR2_PACKAGE_XZ=y
BR2_PACKAGE_ZLIB=y
BR2_PACKAGE_ZSTD=y

#
# Security & SSL/TLS
#
BR2_PACKAGE_OPENSSL=y
BR2_PACKAGE_CA_CERTIFICATES=y
BR2_PACKAGE_LIBSECCOMP=y

#
# Time Synchronization
#
BR2_PACKAGE_CHRONY=y

#
# Python Runtime (for AI tools)
#
BR2_PACKAGE_PYTHON3=y
BR2_PACKAGE_PYTHON3_PY_PYC=y
BR2_PACKAGE_PYTHON_NUMPY=y

#
# Libraries
#
BR2_PACKAGE_PROTOBUF=y
BR2_PACKAGE_FLATBUFFERS=y
BR2_PACKAGE_JSON_C=y

#
# AI/ML Frameworks
#
BR2_PACKAGE_EMLEARN=y

#
# NeuraParse Custom Packages
#
BR2_PACKAGE_NPIE=y
BR2_PACKAGE_NPI_INIT=y
BR2_PACKAGE_NEURAOS_TESTS=y

